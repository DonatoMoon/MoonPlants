/apps/web/out/
/apps/web/build
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js Typescript
/apps/web/*.tsbuildinfo
/apps/web/next-env.d.ts

# Vercel
/apps/web/.vercel
.vercel

# Supabase
/apps/web/supabase/.temp/
/apps/web/supabase/.branches/

# Python / ML
__pycache__/
*.py[cod]
*$py.class
/services/**/.pytest_cache/
/services/**/.venv/
/services/**/venv/
/services/**/env/
